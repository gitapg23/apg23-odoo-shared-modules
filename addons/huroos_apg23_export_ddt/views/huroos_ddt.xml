<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="huroos_delivery_note_tree_view" model="ir.ui.view">
            <field name="name">huroos_delivery_note_tree_view</field>
            <field name="model">huroos.delivery.note</field>
            <field name="inherit_id" ref="huroos_ddt.huroos_delivery_note_tree_view"/>
            <field name="arch" type="xml">
                <field name="invoice_ids" position="after">
                    <field name="export_ddt_info" column_invisible="1"/>
                    <field name="txt_id" invisible="export_ddt_info == False"/>
                </field>
            </field>
        </record>

        <record id="huroos_delivery_note_form_view" model="ir.ui.view">
            <field name="name">huroos_delivery_note_form_view</field>
            <field name="model">huroos.delivery.note</field>
            <field name="inherit_id" ref="huroos_ddt.huroos_delivery_note_form_view"/>
            <field name="arch" type="xml">
                <label for="gross_weight" position="before">
                    <field name="installation_code"/>
                </label>
                <xpath expr="//header" position="inside">
                    <field name="export_ddt_info" invisible="1"/>
                    <button name="btn_export_ddt_info" string="Esporta DDT" type="object" class="btn-primary" invisible="export_ddt_info == False or txt_id"/>
                </xpath>
                <field name="ddt_type_id" position="after">
                    <field name="txt_id" invisible="export_ddt_info == False"/>
                </field>
            </field>
        </record>
    </data>
</odoo>