<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="res_config_settings_jde_csv_export_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.jde.csv.export.form.view</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='connectors_setting_container']" position="after">
                <h2>FTP per CIMAS ddt export</h2>
                <div class="row mt16 o_settings_container" id="ftp_so_csv_export">
                    <div class="col-xs-12 col-md-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <label for="so_ftp_host_export"/>
                            <field name="so_ftp_host_export"/>
                        </div>
                    </div>
                    <div class="col-xs-12 col-md-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <label for="so_ftp_user_export"/>
                            <field name="so_ftp_user_export"/>
                        </div>
                    </div>
                    <div class="col-xs-12 col-md-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <label for="so_ftp_password_export"/>
                            <field name="so_ftp_password_export"/>
                        </div>
                    </div>
                    <div class="col-xs-12 col-md-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <label for="so_ftp_path_export"/>
                            <field name="so_ftp_path_export"/>
                        </div>
                    </div>
                    <div class="col-xs-12 col-md-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <label for="so_ftp_operating_mode"/>
                            <field name="so_ftp_operating_mode"/>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
