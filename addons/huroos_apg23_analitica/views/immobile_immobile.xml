            <field name="model">immobile.immobile.codice</field>
            <field name="inherit_id" ref="huroos_apg23.codice_immobile_form_view"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='immobile_ids']" position="after">
